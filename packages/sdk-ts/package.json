{
  "name": "portaldot-pns",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Portal Naming Service (.pot) — ENS-style names on the Portaldot chain. Resolve names, reverse-resolve addresses, namehash, on any node (devnet, mainnet, or your own RPC).",
  "license": "MIT",
  "author": "Romario Kavin",
  "homepage": "https://github.com/RomarioKavin1/PortalNamingService#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RomarioKavin1/PortalNamingService.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/RomarioKavin1/PortalNamingService/issues"
  },
  "keywords": [
    "portaldot",
    "pns",
    "naming-service",
    "ens",
    "polkadot",
    "substrate",
    "ink",
    "namehash",
    "web3",
    "blockchain",
    "pot"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "@polkadot/api": "^16.5.6",
    "@polkadot/types": "^16.5.6",
    "@polkadot/util": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
