{
  "name": "@portal-name/sdk",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript SDK for the Portal Naming Service (.pot) on Portaldot",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "@polkadot/api": "^16.5.6",
    "@polkadot/types": "^16.5.6",
    "@polkadot/util": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
