# Rust
target/
**/target/
Cargo.lock

# Vendored deps from toolchain build attempts
**/vendor/

# Generated per-crate source-replacement configs (one-off probes). The
# project-root .cargo/config.toml IS intentional (frozen-index replacement)
# and must be tracked.
contracts/**/.cargo/config.toml

# Node
node_modules/
.next/
dist/

# Python
.venv/
__pycache__/
*.pyc

# ink! build artifacts kept under contracts/*/target are ignored above

# Per-deploy run state (dev-node resets on restart, so addresses are ephemeral)
scripts/*_address.txt

# Local secrets
.env
*.local
app/tsconfig.tsbuildinfo
