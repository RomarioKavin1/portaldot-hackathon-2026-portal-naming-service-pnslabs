# Copy to .env.local and fill in from scripts/pns_addresses.json
# (`. .venv/bin/activate && cd scripts && python3 deploy_pns.py`
# writes those addresses).

# ── Testnet (Portaldot dev node) ─────────────────────────────────────────
NEXT_PUBLIC_PORTALDOT_WSS=wss://portaldot.philotheephilix.in
NEXT_PUBLIC_PNS_REGISTRY=
NEXT_PUBLIC_PNS_POT_REGISTRAR=
NEXT_PUBLIC_PNS_REGISTRAR_CONTROLLER=
NEXT_PUBLIC_PNS_PUBLIC_RESOLVER=
NEXT_PUBLIC_PNS_REVERSE_REGISTRAR=
NEXT_PUBLIC_PNS_SUBNAME_REGISTRAR=

# ── Mainnet (fill these once contracts are deployed; the network switch
#    activates the Mainnet option automatically when they are all set) ─────
NEXT_PUBLIC_PORTALDOT_MAINNET_WSS=wss://mainnet.portaldot.io
NEXT_PUBLIC_PNS_MAINNET_REGISTRY=
NEXT_PUBLIC_PNS_MAINNET_POT_REGISTRAR=
NEXT_PUBLIC_PNS_MAINNET_REGISTRAR_CONTROLLER=
NEXT_PUBLIC_PNS_MAINNET_PUBLIC_RESOLVER=
NEXT_PUBLIC_PNS_MAINNET_REVERSE_REGISTRAR=
